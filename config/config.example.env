# Copy this to a dotfiles-managed location and point $HERDR_TN_CONFIG at it,
# e.g. in your shell profile (managed by nix/chezmoi):
#   export HERDR_TN_CONFIG="$HOME/.config/herdr-terminal-notifier/config.env"
#
# Every key below is optional. Resolution order (later wins):
#   1. built-in default (lib/config.sh)
#   2. environment variable (exported before notify.sh runs)
#   3. $HERDR_PLUGIN_CONFIG_DIR/config.env  (herdr-managed, per machine)
#   4. $HERDR_TN_CONFIG                       (this file)
# So any key here overrides both the built-in default and an env var of the same
# name; unset keys keep whatever the env var or built-in default provides. Note
# an env var exported EMPTY (e.g. `export NOTIFIER=`) counts as unset and falls
# back to the built-in default — set the key here to force an empty value.

# Which NEW agent statuses trigger a notification (space separated).
# Valid: working blocked idle done unknown
TRIGGER_STATUSES="blocked done"

# Stay quiet for the workspace you are currently looking at (1 to enable).
# Only suppresses when the workspace is focused inside herdr AND a terminal from
# TERMINAL_APP_IDS is the frontmost macOS app — so switching to the browser while
# an agent runs still lets its notification through.
SUPPRESS_FOCUSED=1

# Bundle ids (space separated) of terminal apps that host herdr, for the
# frontmost check above. Empty or undetectable -> suppression is skipped (fail
# open). Find an app's id with:  osascript -e 'id of app "Ghostty"'
TERMINAL_APP_IDS="com.mitchellh.ghostty com.apple.Terminal com.googlecode.iterm2 net.kovidgoyal.kitty com.github.wez.wezterm org.alacritty"

# Drop a repeated (pane,status) seen within this many seconds.
DEBOUNCE_SECONDS=2

# Delete per-pane state files (laststatus-*/debounce-*) older than this many days.
# Pane ids are ephemeral, so these would otherwise pile up in a persistent state
# dir. The sweep runs at most once a day (gated by a .state-swept sentinel).
STATE_SWEEP_DAYS=7

# Click the notification to jump to the agent that changed.
ACTIVATE_ON_CLICK=1
# {pane}/{workspace}/{agent} are substituted before running `herdr <CLICK_COMMAND>`.
# The template text is interpreted by a shell, so its literal words are split
# into command arguments; the substituted VALUES are shell-quoted, so each
# expands to exactly one literal argument (a value can't inject shell syntax).
# Do NOT quote placeholders yourself ("{pane}") — values arrive pre-quoted and
# would end up double-escaped.
CLICK_COMMAND="agent focus {pane}"

# Notifier binary. Empty = bundled assets/HerdrNotify.app (herdr left icon).
# Set an absolute path to use a different terminal-notifier build.
# NOTIFIER=""

# How often (seconds) to refresh the bundled app's Launch Services registration.
# Self-heals the left icon if the registration goes stale (reboots, OS updates).
# Default 6h.
# REGISTER_TTL_SECONDS=21600

# Right-side image mode. The LEFT icon is always the notifier app's (herdr logo).
ICON_MODE=contentImage

# Per-status look & feel. Placeholders:
#   {agent} {workspace} {worktree} {tab} {pane} {session} {old_status} {new_status} {cwd}
TITLE_BLOCKED="⏳ {agent} needs input"
BODY_BLOCKED="{workspace} · {worktree}"
ICON_BLOCKED="assets/icons/blocked.png"
SOUND_BLOCKED="Glass"

TITLE_DONE="✅ {agent} done"
BODY_DONE="{workspace} · {worktree}"
ICON_DONE="assets/icons/done.png"
SOUND_DONE="Hero"

# Fallback for any other triggered status.
TITLE_DEFAULT="{agent}: {new_status}"
BODY_DEFAULT="{workspace} · {worktree}"
ICON_DEFAULT="assets/icons/working.png"
SOUND_DEFAULT="none"

# Uncomment to dump raw event/context JSON to the state dir for debugging.
# DEBUG=1
